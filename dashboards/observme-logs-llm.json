  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "LLM prompt/response size histograms measured in characters and filterable by provider/model. These *_size_chars metrics work even when content capture is disabled and must not be interpreted as bytes.",
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum(rate(observme_prompt_size_chars_bucket{provider=~\"${provider:regex}\", model=~\"${model:regex}\"}[$__rate_interval])) by (le))",
          "legendFormat": "prompt p95",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum(rate(observme_response_size_chars_bucket{provider=~\"${provider:regex}\", model=~\"${model:regex}\"}[$__rate_interval])) by (le))",
          "legendFormat": "response p95",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "LLM input/output size p95 (characters)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Interval token deltas by selected provider/model for input, output, total, reasoning, and cache token families.",
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(increase(observme_llm_input_tokens_total{provider=~\"${provider:regex}\", model=~\"${model:regex}\"}[$__interval])) by (provider, model)",
          "legendFormat": "input {{provider}}/{{model}}",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(increase(observme_llm_output_tokens_total{provider=~\"${provider:regex}\", model=~\"${model:regex}\"}[$__interval])) by (provider, model)",
          "legendFormat": "output {{provider}}/{{model}}",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(increase(observme_llm_total_tokens_total{provider=~\"${provider:regex}\", model=~\"${model:regex}\"}[$__interval])) by (provider, model)",
          "legendFormat": "total {{provider}}/{{model}}",
          "range": true,
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(increase(observme_llm_reasoning_tokens_total{provider=~\"${provider:regex}\", model=~\"${model:regex}\"}[$__interval])) by (provider, model)",
          "legendFormat": "reasoning {{provider}}/{{model}}",
          "range": true,
          "refId": "D"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(increase(observme_llm_cache_read_tokens_total{provider=~\"${provider:regex}\", model=~\"${model:regex}\"}[$__interval])) by (provider, model)",
          "legendFormat": "cache read {{provider}}/{{model}}",
          "range": true,
          "refId": "E"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(increase(observme_llm_cache_write_tokens_total{provider=~\"${provider:regex}\", model=~\"${model:regex}\"}[$__interval])) by (provider, model)",
          "legendFormat": "cache write {{provider}}/{{model}}",
          "range": true,
          "refId": "F"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(increase(observme_llm_cache_write_1h_tokens_total{provider=~\"${provider:regex}\", model=~\"${model:regex}\"}[$__interval])) by (provider, model)",
          "legendFormat": "cache write 1h {{provider}}/{{model}}",
          "range": true,
          "refId": "G"
        }
      ],
      "title": "LLM token trends by type",
      "type": "timeseries"
    },
    {
      "datasource": null,
      "description": "Navigation panel for optional redacted LLM content. This dashboard keeps lifecycle metrics/logs here and sends prompt, response, and thinking bodies to the canonical conversation view.",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 3,
      "links": [
        {
          "targetBlank": false,
          "title": "Open canonical LLM Conversations",
          "url": "/d/observme-llm-conversations/observme-llm-conversations?${__url_time_range}&${session_id:queryparam}&${workflow_id:queryparam}&${agent_id:queryparam}&${agent_run_id:queryparam}&${provider:queryparam}&${model:queryparam}&${content_kind:queryparam}"
        }
      ],
      "options": {
        "code": {
          "language": "plaintext",
          "showLineNumbers": false,
          "showMiniMap": false
        },
        "content": "## Canonical LLM conversation drill-down\n\nPrompts, responses, and thinking are redacted, opt-in content. Open **ObservMe LLM Conversations** with the current session/workflow/agent/run/provider/model/content-kind filters for the canonical timeline. Empty content can mean capture is disabled or no matching events exist. Do not query by raw prompt, response, or thinking text.",
        "mode": "markdown"
      },
      "pluginVersion": "11.1.0",
      "title": "Canonical LLM conversation drill-down",
      "type": "text"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "Recent LLM request lifecycle logs filtered by session, workflow, agent, run, provider, and model labels. Use the canonical LLM Conversations link for redacted prompt/response/thinking bodies and Tempo/Trace Journey for waterfalls.",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{service_name=\"observme-pi-extension\", pi_session_id=~\"${session_id:regex}\", pi_workflow_id=~\"${workflow_id:regex}\", pi_agent_id=~\"${agent_id:regex}\", pi_agent_run_id=~\"${agent_run_id:regex}\", gen_ai_provider_name=~\"${provider:regex}\", gen_ai_request_model=~\"${model:regex}\", event_name=~\"llm[.]request[.](started|completed|failed)\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "LLM request logs",
      "type": "logs",
      "links": [
        {
          "targetBlank": false,
          "title": "Open canonical LLM Conversations",
          "url": "/d/observme-llm-conversations/observme-llm-conversations?${__url_time_range}&${session_id:queryparam}&${workflow_id:queryparam}&${agent_id:queryparam}&${agent_run_id:queryparam}&${provider:queryparam}&${model:queryparam}&${content_kind:queryparam}"
