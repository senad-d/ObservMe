          "editorMode": "code",
          "expr": "{service_name=\"observme-pi-extension\", event_name=\"tool.error.captured\", event_category=\"tool_content\"} | json | line_format \"{{.body}}\"",
          "legendFormat": "{{pi_tool_name}} / {{error_type}}",
          "maxLines": 200,
          "queryType": "range",
          "range": true,
          "refId": "A"
        }
      ],
