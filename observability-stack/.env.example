# -----------------------------------------------------------------------------
# Core settings
# -----------------------------------------------------------------------------

# Public domain used by Nginx and Grafana root URL.
# If changed, update nginx/nginx.conf and TLS certificate names/paths.
OBSERVABILITY_DOMAIN=observability.local

# -----------------------------------------------------------------------------
# Host published ports
# -----------------------------------------------------------------------------

# Nginx is the public UI entrypoint (80 -> 443 redirect + HTTPS on 443).
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# OTLP ports can stay published when ingesting telemetry from outside Compose.
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318

# -----------------------------------------------------------------------------
# Internal service ports (container network and health checks)
# -----------------------------------------------------------------------------

GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
LOKI_PORT=3100

# Tempo query + ingest ports.
TEMPO_PORT=3200
TEMPO_GRPC_PORT=9095
TEMPO_OTLP_GRPC_PORT=4317
TEMPO_OTLP_HTTP_PORT=4318

# OTel Collector self metrics, Prometheus exporter metrics, and health endpoint.
OTEL_SELF_METRICS_PORT=8888
OTEL_PROM_EXPORT_PORT=8889
OTEL_HEALTH_PORT=13133

# -----------------------------------------------------------------------------
# Application defaults
# -----------------------------------------------------------------------------

# Password is loaded from /run/secrets/grafana_admin_password.
GRAFANA_ADMIN_USER=admin

# Data retention windows.
PROMETHEUS_RETENTION=15d
LOKI_RETENTION=168h
TEMPO_RETENTION=168h

# -----------------------------------------------------------------------------
# Online mode storage (S3-backed Loki and Tempo)
# -----------------------------------------------------------------------------

# Keep false to allow IAM role credentials via instance metadata.
# On EC2, if services run in Docker bridge networking, IMDS hop limit must be >= 2.
AWS_EC2_METADATA_DISABLED=true
# Optional static credentials; leave unset to use IAM role.
S3_AWS_ACCESS_KEY_ID=change_me
S3_AWS_SECRET_ACCESS_KEY=change_me
#AWS_SESSION_TOKEN=

# -----------------------------------------------------------------------------
# Online mode metrics (CloudWatch datasources)
# -----------------------------------------------------------------------------
CLOUDWATCH_AWS_ACCESS_KEY_ID=change_me
CLOUDWATCH_AWS_SECRET_ACCESS_KEY=change_me

DEV_CLOUDWATCH_ROLE=change_me

# Tempo S3 settings (docker-compose.online.yml + config/tempo/tempo.s3.yaml).
# Keep credentials out of this file; prefer IAM role or exported AWS_* vars.
TEMPO_S3_BUCKET=your-tempo-bucket-name
TEMPO_S3_REGION=us-east-1
TEMPO_S3_PREFIX=tempo
# Keep non-empty. For AWS S3 use s3.amazonaws.com.
# Override for S3-compatible stores (for example MinIO, Ceph RGW).
TEMPO_S3_ENDPOINT=s3.amazonaws.com
# true only for non-TLS S3-compatible endpoints (for example local MinIO over HTTP).
TEMPO_S3_INSECURE=false

# Loki S3 settings (docker-compose.online.yml + config/loki/loki.s3.yaml).
# Keep credentials out of this file; prefer IAM role or exported AWS_* vars.
LOKI_S3_BUCKET=your-loki-bucket-name
LOKI_S3_REGION=us-east-1
# Keep non-empty. For AWS S3 use s3.amazonaws.com.
# Override for S3-compatible stores (for example MinIO, Ceph RGW).
LOKI_S3_ENDPOINT=s3.amazonaws.com
# true only for S3-compatible stores that require path-style URLs.
LOKI_S3_FORCE_PATH_STYLE=false
# true only for non-TLS S3-compatible endpoints.
LOKI_S3_INSECURE=false

# -----------------------------------------------------------------------------
# Compose resource limits (docker compose, non-swarm)
# -----------------------------------------------------------------------------

NGINX_MEM_LIMIT=128m
NGINX_CPUS=0.10
GRAFANA_MEM_LIMIT=768m
GRAFANA_CPUS=0.20
OTEL_MEM_LIMIT=384m
OTEL_CPUS=0.20
PROMETHEUS_MEM_LIMIT=1792m
PROMETHEUS_CPUS=0.35
LOKI_MEM_LIMIT=1280m
LOKI_CPUS=0.20
TEMPO_MEM_LIMIT=1536m
TEMPO_CPUS=0.20
NODE_EXPORTER_MEM_LIMIT=128m
NODE_EXPORTER_CPUS=0.05
CADVISOR_MEM_LIMIT=256m
CADVISOR_CPUS=0.10
