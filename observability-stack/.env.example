# Public Grafana URL served by Nginx.
OBSERVABILITY_DOMAIN=localhost
OBSERVABILITY_URL=http://localhost
NGINX_HTTP_PORT=80

# Host-published OTLP ports.
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318

# Internal service ports used by Compose health checks and service discovery.
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
LOKI_PORT=3100
TEMPO_PORT=3200
TEMPO_GRPC_PORT=9095
TEMPO_OTLP_GRPC_PORT=4317
TEMPO_OTLP_HTTP_PORT=4318
OTEL_SELF_METRICS_PORT=8888
OTEL_PROM_EXPORT_PORT=8889
OTEL_HEALTH_PORT=13133

# Grafana password is loaded from secrets/grafana_admin_password.
GRAFANA_ADMIN_USER=admin
PROMETHEUS_RETENTION=15d

# Compose resource limits.
NGINX_MEM_LIMIT=128m
NGINX_CPUS=0.10
GRAFANA_MEM_LIMIT=768m
GRAFANA_CPUS=0.20
OTEL_MEM_LIMIT=384m
OTEL_CPUS=0.20
PROMETHEUS_MEM_LIMIT=1792m
PROMETHEUS_CPUS=0.35
LOKI_MEM_LIMIT=1280m
LOKI_CPUS=0.20
TEMPO_MEM_LIMIT=1536m
TEMPO_CPUS=0.20
NODE_EXPORTER_MEM_LIMIT=128m
NODE_EXPORTER_CPUS=0.05
CADVISOR_MEM_LIMIT=256m
CADVISOR_CPUS=0.10
